<?php
$formKey = $block->getFormKey(); // This gets the CSRF token
?>

<div style="display: flex; flex-direction: row; gap: 12px; align-items: center;">
    <button id="export_customers_btn" type="button"><?= $block->getButtonCaption(); ?></button>
    <label>
        <input id="export_customers_force_chk" type="checkbox" />
        <?= $block->getForceCheckboxLabel(); ?>
    </label>
</div>

<script>
    require(['jquery'], function($) {
        $('#export_customers_btn').click(function() {
            var force = $('#export_customers_force_chk').prop('checked');

            $.ajax({
                url: '<?= $block->getAjaxUrl() ?>',
                type: 'POST',
                data: {
                    form_key: '<?= $formKey ?>',
                    force: force,
                    count_only: true
                },
                showLoader: true,
                success: function(response) {
                    var count = parseInt(response.count, 10) || 0;
                    var customerLabel = count === 1 ? 'customer' : 'customers';
                    var confirmMessage = 'Export ' + count + ' ' + customerLabel + '?';

                    if (!confirm(confirmMessage)) {
                        return;
                    }

                    exportCustomers(force);
                },
                error: function(response) {
                    alert(response.message);
                }
            });

            function exportCustomers(force) {
                $.ajax({
                    url: '<?= $block->getAjaxUrl() ?>',
                    type: 'POST',
                    data: {
                        form_key: '<?= $formKey ?>',
                        force: force
                    },
                    showLoader: true,
                    success: function(response) {
                        alert(response.message || 'Export completed.');
                    },
                    error: function(response) {
                        alert(response.message);
                    }
                });
            }
        });
    });
</script>
